<Application x:Class="OperatingSystemSimulator.App"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- Load WinUI resources -->
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
        <!-- Load Uno.UI.Toolkit resources -->
        <ToolkitResources xmlns="using:Uno.Toolkit.UI" />
      </ResourceDictionary.MergedDictionaries>

      <FontFamily x:Key="ContentControlThemeFontFamily">ms-appx:///Assets/Fonts/OpenSansRegular.ttf#Open Sans, Noto Color Emoji, Apple Color Emoji, Segoe UI Emoji, Segoe UI Symbol, Segoe UI, Ubuntu, sans-serif</FontFamily>
    </ResourceDictionary>
  </Application.Resources>

</Application>
