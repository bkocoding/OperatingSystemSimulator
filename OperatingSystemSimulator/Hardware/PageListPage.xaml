<Page
    x:Class="OperatingSystemSimulator.Hardware.PageListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OperatingSystemSimulator.Hardware"
    xmlns:converters="using:OperatingSystemSimulator.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#333333">

  <Page.Resources>
    <converters:BooleanToColorConverter x:Key="BooleanToColorConverter" />
  </Page.Resources>

  <Grid>
    <ScrollViewer>
      <ItemsControl ItemsSource="{Binding Pages}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel Orientation="Horizontal" Width="500" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Width="50" Height="50" Margin="5" CornerRadius="5" Background="{Binding IsAllocated, Converter={StaticResource BooleanToColorConverter}}">
              <TextBlock Text="{Binding PageNumber}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" />
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</Page>
