<UserControl
    x:Class="OperatingSystemSimulator.Apps.WebBrowser.Pages.HorizonMusicPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
>

  <Grid Background="DarkCyan" Height="357" Width="698">

    <Grid.RowDefinitions>
      <RowDefinition Height="120"/>
      <RowDefinition Height="50"/>
      <RowDefinition Height="80"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="Horizon Music" FontSize="24" Foreground="Black" FontWeight="Bold" HorizontalAlignment="Center" Margin="20"/>

    <TextBlock x:Name="PlayingTextBlock" Grid.Row="1" Text="Now Playing: 'I Can't Stop' by Punch Deck" FontSize="16" Foreground="Black" HorizontalAlignment="Center" Visibility="Collapsed"/>
    <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" Orientation="Horizontal">
      <Button x:Name="PlayButton" Content="Play" Foreground="Black" Click="PlayButton_Click" Width="100" />
      <Button x:Name="PauseButton" Content="Pause" Foreground="Black" Click="PauseButton_Click" Width="100" IsEnabled="False"/>
      <Button x:Name="StopButton" Content="Stop" Foreground="Black" Click="StopButton_Click" Width="100" IsEnabled="False"/>
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <TextBlock Text="Vol:" FontSize="14" Foreground="Black" VerticalAlignment="Center" Margin="5,0"/>
        <Slider x:Name="VolumeSlider" Minimum="0" Maximum="100" Value="100" Width="100" ValueChanged="VolumeSlider_ValueChanged" PointerPressed="Slider_PointerPressed"/>
      </StackPanel>
    </StackPanel>
    <StackPanel Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" Orientation="Vertical">
      <Slider x:Name="SeekSlider" Minimum="0" Maximum="100" ValueChanged="SeekSlider_ValueChanged" Width="300" IsEnabled="False" PointerPressed="Slider_PointerPressed"/>
      <TextBlock x:Name="CurrentTimeText" Foreground="Black" Text="00:00 / 00:00" HorizontalAlignment="Center" />
    </StackPanel>
  </Grid>
</UserControl>
